{
	"name": "talimio",
	"private": true,
	"version": "0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"cf:build": "pnpm --dir ../talimio-landing build && pnpm run build:prod && rm -rf ../dist && mkdir -p ../dist/app && cp -R ../talimio-landing/dist/. ../dist/ && cp -R dist/. ../dist/app/",
		"cf:dev": "pnpm run cf:build && npx wrangler pages dev ../dist --local-protocol=https",
		"lint": "biome check --write",
		"knip": "knip",
		"lint:knip": "pnpm run knip",
		"lint:eslint": "eslint --fix",
		"lint:all": "pnpm run lint src && pnpm run lint:eslint src",
		"preview": "vite preview",
		"build:prod": "vite build --mode prod",
		"test": "vitest run"
	},
